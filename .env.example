# Discord Bot
DISCORD_PUBLIC_KEY=              # From Discord Developer Portal → General Information
DISCORD_APP_ID=                  # From Discord Developer Portal → OAuth2 → Client ID
DISCORD_BOT_TOKEN=               # From Discord Developer Portal → Bot → Reset Token
DISCORD_GUILD_ID=                # Your test server ID (for guild command registration)
DISCORD_RESULTS_WEBHOOK_URL=     # Webhook URL for #league-results channel

# Shopify Storefront API
SHOPIFY_DOMAIN=crypticcabin.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=        # Public Storefront API token (no admin access needed)

# Appointo (Table Hire Booking)
APPOINTO_TOKEN=                  # From Appointo app → Plans & Settings → API access

# Strapi Backend
STRAPI_URL=                      # Base URL of the Strapi backend (e.g. https://your-strapi.cloud)
STRAPI_API_TOKEN=                # Optional: Strapi read-only API token

# Frontend
FRONTEND_URL=https://leagues.crypticcabin.com
